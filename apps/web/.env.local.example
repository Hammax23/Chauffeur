# Google Maps API Key
# Get your API key from: https://console.cloud.google.com/google/maps-apis
# Enable these APIs: Maps JavaScript API, Geocoding API, Directions API, Places API
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# Server-side Places + Directions (mobile app via /api/places/*).
# Recommended: create a separate key with "Application restrictions: IP addresses" (your server)
# or "None" for dev — do NOT use HTTP referrer–only keys here or requests will fail with REQUEST_DENIED.
GOOGLE_MAPS_SERVER_KEY=

# OAuth (Customer social login)
# Comma-separated client IDs (audiences) that your mobile app uses.
GOOGLE_OAUTH_CLIENT_IDS=

# Apple audience(s). For Expo iOS native sign-in, this is usually the iOS bundle identifier.
APPLE_CLIENT_ID=com.sarjworldwide.chauffeur

# --- Driver registration emails ---
# Option A — Resend (preferred): verify sending domain at https://resend.com
RESEND_API_KEY=

# Option B — If RESEND_API_KEY is unset or Resend fails, the API falls back to Hostinger SMTP (same as contact form).
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASSWORD=

# New driver applications are also emailed here (defaults to reserve@sarjworldwide.com if empty).
ADMIN_EMAIL=

# Cloudflare Turnstile — driver registration form (must match site key / secret pair in Cloudflare dashboard)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Operational Manager accounts are created in Admin → Operational Managers (email + password per user).
# Same JWT_SECRET signs their session cookies as admin.
