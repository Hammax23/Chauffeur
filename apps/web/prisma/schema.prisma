// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Reservation {
  id                  String   @id @default(cuid())
  bookingId           String   @unique
  dateSubmitted       DateTime @default(now())
  status              String   @default("PENDING")
  
  // Customer Info
  firstName           String
  lastName            String
  email               String
  phone               String
  
  // Service Details
  serviceType         String
  vehicle             String
  passengers          Int      @default(1)
  childSeats          Int      @default(0)
  childSeatType       String?
  etr407              String   @default("No")
  
  // Trip Details
  serviceDate         String
  serviceTime         String
  pickupLocation      String
  stops               String?
  dropoffLocation     String
  distance            String?
  duration            String?
  
  // Flight Info
  airline             String?
  flightNumber        String?
  flightNote          String?
  
  // Pricing
  rideFare            Float    @default(0)
  stopCharge          Float    @default(0)
  childSeatCharge     Float    @default(0)
  subtotal            Float    @default(0)
  hst                 Float    @default(0)
  gratuity            Float    @default(0)
  total               Float    @default(0)
  
  // Additional
  specialRequirements String?
  driverLink          String?
  trackLink           String?
  completedAt         DateTime?
  statusUpdatedAt     DateTime?

  /// First transition to ON THE WAY — used for total trip duration (→ DONE).
  driverOnTheWayAt    DateTime?
  /// JSON array: [{ "start": ISO, "end"?: ISO }, ...] stop intervals (Stop tap → Continue tap).
  driverStopPeriodsJson String?
  
  // Payment Info (Stripe)
  stripeCustomerId       String?
  stripePaymentMethodId  String?
  cardType               String?
  cardLast4              String?
  paymentStatus          String?  @default("PENDING")
  
  // Driver Response Tracking
  driverResponse      String?  // "ACCEPTED", "REJECTED", null (pending)
  driverRespondedAt   DateTime?
  rejectedDriverIds   String?  // Comma-separated IDs of drivers who rejected
  
  // Relations
  customerId          String?
  customer            Customer? @relation(fields: [customerId], references: [id])
  assignedDriverId    String?
  assignedDriver      Driver?  @relation(fields: [assignedDriverId], references: [id])
  
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model Driver {
  id            String   @id @default(cuid())
  driverId      String   @unique
  name          String
  phone         String
  email         String   @unique
  password      String
  vehicle       String
  vehiclePlate  String
  vehicleCode   String?
  status        String   @default("available")
  isActive      Boolean  @default(false)
  photo         String?
  rating        Float    @default(5.0)
  totalTrips    Int      @default(0)
  pushToken     String?  // Expo push notification token

  /// Last known live location (updated by driver app while in use)
  lastLatitude            Float?
  lastLongitude           Float?
  lastLocationAccuracy    Float?
  lastLocationHeading     Float?
  lastLocationSpeed       Float?
  lastLocationUpdatedAt   DateTime?

  backgroundCheckUrl           String?
  commercialInsuranceUrl       String?
  driverLicenceUrl             String?
  proofOfWorkEligibilityUrl    String?
  municipalTaxiLimoLicenceUrl  String?
  vehicleInsuranceUrl          String?
  vehicleRegistrationUrl       String?
  
  reservations  Reservation[]
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Quote {
  id              String   @id @default(cuid())
  quoteId         String   @unique
  status          String   @default("NEW")
  
  passengerName   String
  passengers      String
  phone           String
  email           String
  
  serviceType     String
  vehicle         String?
  pickupTime      String?
  pickupLocation  String
  stops           String?
  dropoffLocation String
  additionalNotes String?
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Customer {
  id            String   @id @default(cuid())
  firstName     String
  lastName      String
  email         String   @unique
  phone         String   @default("")
  password      String
  city          String?
  photo         String?

  /// OAuth provider account linking (e.g. google/apple). If set, password login still exists but should be treated as internal.
  oauthProvider String?
  oauthSub      String?

  /// Where this customer account was created (e.g. "app" via mobile, "web" via website/admin).
  registrationSource String @default("web")
  
  reservations  Reservation[]
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([oauthProvider, oauthSub])
}

model DriverInvite {
  id            String    @id @default(cuid())
  token         String    @unique
  email         String?
  name          String?

  /// Which registration fields the driver sees (JSON: name, email, phone, vehicle, vehiclePlate, photo — booleans). Legacy rows = all visible.
  visibleFields     Json?
  /// Admin-provided values for fields hidden from the driver (same keys as strings).
  prefilledFields   Json?
  
  status        String    @default("PENDING")
  expiresAt     DateTime
  usedAt        DateTime?
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  applications  DriverApplication[]
}

model DriverApplication {
  id            String   @id @default(cuid())

  inviteId      String
  invite        DriverInvite @relation(fields: [inviteId], references: [id], onDelete: Cascade)

  status        String   @default("SUBMITTED") // SUBMITTED | APPROVED | REJECTED
  rejectionReason String?

  /// Snapshot of submitted registration details (immutable record)
  name          String
  email         String
  phone         String
  vehicle       String
  vehiclePlate  String
  photo         String?

  backgroundCheckUrl           String?
  commercialInsuranceUrl       String?
  driverLicenceUrl             String?
  proofOfWorkEligibilityUrl    String?
  municipalTaxiLimoLicenceUrl  String?
  vehicleInsuranceUrl          String?
  vehicleRegistrationUrl       String?

  submittedAt   DateTime @default(now())
  reviewedAt    DateTime?

  documents     DriverApplicationDocument[]

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([status, submittedAt])
  @@unique([inviteId])
}

model DriverApplicationDocument {
  id              String   @id @default(cuid())
  applicationId   String
  application     DriverApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  /// One of the invite document keys (e.g. backgroundCheck, driverLicence, vehicleInsurance, ...)
  key             String
  url             String

  /// OCR extraction result (best-effort)
  extractedExpiryDate  DateTime?
  ocrConfidence        Float?

  /// Confirmed expiry date (driver-confirmed or admin-corrected)
  confirmedExpiryDate  DateTime?
  expirySource         String   @default("OCR") // OCR | DRIVER | ADMIN

  /// Review / gating
  status          String   @default("PENDING") // PENDING | VALID | EXPIRED | MISMATCH | MISSING
  overrideReason  String?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([applicationId, key])
  @@index([key])
  @@index([status])
}

/// Operational managers: limited panel (/operational-manager) — assign drivers only. Created by admin.
model OperationalManager {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive])
}

/// Fleet vehicles for online reservation pricing
model FleetVehicle {
  id            String   @id @default(cuid())
  vehicleId     String   @unique  // e.g. "cadillac-xts"
  name          String             // e.g. "Cadillac XTS"
  dropdownName  String             // e.g. "LUXURY SEDAN"
  description   String
  image         String
  category      String             // Sedan, SUV, Van, Executive, Coach
  seating       String             // e.g. "3 maximum, 3 comfortable"
  luggage       String             // e.g. "2 large, 2 medium"
  
  // Pricing
  hourlyRate    Float              // Hourly rate for reservation
  pricePerKm    Float              // Per-kilometer rate
  
  // Settings
  isActive      Boolean  @default(true)
  sortOrder     Int      @default(0)
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([isActive, sortOrder])
}

/// Extra charges configuration for reservations
model ReservationCharges {
  id              String   @id @default(cuid())
  chargeKey       String   @unique  // e.g. "stop", "childSeat", "meetGreet", "bouquet"
  chargeName      String             // Display name
  amount          Float              // Charge amount in dollars
  isPercentage    Boolean  @default(false)  // If true, amount is percentage
  isActive        Boolean  @default(true)
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

/// Global SEO settings (single row, id = "global")
model SeoSettings {
  id                    String   @id @default("global")
  siteUrl               String   @default("https://sarjworldwide.ca")
  siteName              String   @default("SARJ Worldwide Chauffeur Services")
  titleTemplate         String   @default("%s | SARJ Worldwide Chauffeur")
  defaultTitle          String   @default("SARJ Worldwide Chauffeur Services | Premium Luxury Transportation")
  defaultDescription    String   @default("SARJ Worldwide chauffeur services. Airport transfers, corporate travel, weddings, VIP transport & city tours.")
  defaultKeywords       String?
  defaultOgImage        String?
  twitterHandle         String?
  twitterCardType       String   @default("summary_large_image")
  googleVerification    String?
  bingVerification      String?
  yandexVerification    String?
  pinterestVerification String?
  facebookAppId         String?
  ga4Id                 String?
  gtmId                 String?
  facebookPixelId       String?
  organizationName      String?
  organizationLogo      String?
  organizationPhone     String?
  organizationEmail     String?
  organizationAddress   String?
  organizationCity      String?
  organizationRegion    String?
  organizationPostal    String?
  organizationCountry   String   @default("CA")
  localBusinessSchema   Json?
  websiteSchema         Json?
  robotsExtraRules      String?
  sitemapEnabled        Boolean  @default(true)
  defaultChangeFreq     String   @default("weekly")
  defaultPriority       Float    @default(0.8)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

/// Per-page SEO overrides
model SeoPage {
  id                  String    @id @default(cuid())
  path                String    @unique
  pageType            String    @default("static")
  pageLabel           String?
  title               String?
  metaDescription     String?
  keywords            String?
  canonicalUrl        String?
  ogTitle             String?
  ogDescription       String?
  ogImage             String?
  twitterTitle        String?
  twitterDescription  String?
  twitterImage        String?
  h1                  String?
  focusKeyword        String?
  robotsIndex         Boolean   @default(true)
  robotsFollow        Boolean   @default(true)
  noarchive           Boolean   @default(false)
  nosnippet           Boolean   @default(false)
  includeInSitemap    Boolean   @default(true)
  sitemapPriority     Float?
  sitemapChangeFreq   String?
  schemaJson          Json?
  breadcrumbLabel     String?
  headerScripts       String?
  bodyScripts         String?
  internalNotes       String?
  lastAuditedAt       DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@index([pageType])
  @@index([includeInSitemap])
}

/// URL redirects managed by SEO team
model SeoRedirect {
  id              String   @id @default(cuid())
  sourcePath      String   @unique
  destinationPath String
  redirectType    Int      @default(301)
  isActive        Boolean  @default(true)
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([isActive])
}
