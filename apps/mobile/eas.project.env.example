# Copy to `apps/mobile/.env` (same folder as app.config.js)

# Optional — Expo Push (UUID from expo.dev → Project settings). Omit if you don't need push in dev.
# EAS_PROJECT_ID=8c2b91c9-8e3a-4b36-bda1-4dd99a3d01f5
#
# Closed-app (WhatsApp-style) push requires a native build (EAS/TestFlight/Play),
# not Expo Go alone for reliable production. On expo.dev → Credentials:
#   iOS: Push Notifications key / APNs
#   Android: FCM V1 service account
# Also enable Push Notifications capability on the Apple App ID / provisioning profile.

# Optional API (physical device → your Next.js machine). Required for Google address search on device:
# EXPO_PUBLIC_API_BASE_URL=http://192.168.1.10:3000/api
#
# The app calls `/places/autocomplete`, `/places/details`, and `/places/directions` on that host. On the web app, set
# GOOGLE_MAPS_SERVER_KEY (or unrestricted NEXT_PUBLIC_GOOGLE_MAPS_API_KEY) and enable Places API.
