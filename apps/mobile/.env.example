# Copy to apps/mobile/.env then restart Expo: npx expo start -c

# Local dev (iPhone + Expo Go): your PC's LAN IP (same Wi‑Fi) + port 3000
# Example:
# EXPO_PUBLIC_API_BASE_URL=http://192.168.1.10:3000/api

# Preview/Production (TestFlight): should be your live API
# EXPO_PUBLIC_API_BASE_URL=https://sarjworldwide.ca/api
