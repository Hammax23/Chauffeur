{
  "expo": {
    "name": "SARJ Worldwide",
    "slug": "sarj-worldwide",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "sarjworldwide",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1a1a1a"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.sarjworldwide.chauffeur",
      "buildNumber": "4",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1a1a1a"
      },
      "package": "com.sarjworldwide.chauffeur",
      "versionCode": 1,
      "edgeToEdgeEnabled": true
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "./plugins/strip-ios-capabilities.js",
      "@react-native-community/datetimepicker",
      "expo-router",
      "expo-secure-store",
      "expo-font",
      "expo-asset",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "SARJ uses your location to show your live position to dispatch and for ride assignments.",
          "locationAlwaysAndWhenInUsePermission": "SARJ uses your location in the background so dispatch can see you until you log out or close the app.",
          "locationAlwaysPermission": "SARJ uses your location in the background for live driver tracking.",
          "isIosBackgroundLocationEnabled": true,
          "isAndroidForegroundServiceEnabled": true,
          "isAndroidBackgroundLocationEnabled": true
        }
      ]
    ],
    "extra": {
      "GOOGLE_EXPO_CLIENT_ID": "199624638433-v2bm7j4a52pb0kql61thdr9gt98hsucp.apps.googleusercontent.com",
      "GOOGLE_IOS_CLIENT_ID": "REPLACE_ME",
      "GOOGLE_ANDROID_CLIENT_ID": "REPLACE_ME",
      "GOOGLE_WEB_CLIENT_ID": "REPLACE_ME",
      "router": {},
      "eas": {
        "projectId": "8c2b91c9-8e3a-4b36-bda1-4dd99a3d01f5"
      }
    },
    "experiments": {
      "typedRoutes": true
    }
  }
}
